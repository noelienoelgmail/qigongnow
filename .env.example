# Database - update with your PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/qigong?schema=public"

# NextAuth - generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# YouTube Data API v3 key (for fetching playlist durations)
YOUTUBE_API_KEY="your-youtube-api-key-here"

# Resend (for password reset emails) - get key at resend.com
RESEND_API_KEY="re_your-api-key-here"
# From address - must be a verified domain in Resend (use onboarding@resend.dev for testing)
RESEND_FROM="onboarding@resend.dev"
